void UpgradeFactoryCreate(char[] name, bool sim, float location[3])
{
	Log(sim, "Upgrade Factory Creating: %s", name);

	if (!sim)
	{
		int entity = SpawnItem(_, _, _, "upgrade_spawn", _, true);

		// Mod location so it spawns around mid level of model.
		location[2] += 10.0;

		// Create random velocity
		float vel[3];
		vel[0] = GetRandomFloat(-80.0, 80.0);
		vel[1] = GetRandomFloat(-80.0, 80.0);
		vel[2] = GetRandomFloat(40.0, 80.0);

		DispatchKeyValueVector(entity, "origin", location);
		DispatchKeyValue(entity, "spawnflags", "1");

		// Do the individual upgrades
		if (StrContains(name, "laser", false) != -1)
		{
			DispatchKeyValue(entity, "laser_sight", "1");
			DispatchKeyValue(entity, "spawnflags", "2");
		}
		else
			DispatchKeyValue(entity, "laser_sight", "0");

		if (StrContains(name, "incendiary", false) != -1)
			DispatchKeyValue(entity, "upgradepack_incendiary", "1");
		else
			DispatchKeyValue(entity, "upgradepack_incendiary", "0");

		if (StrContains(name, "explosive", false) != -1)
			DispatchKeyValue(entity, "upgradepack_explosive", "1");
		else
			DispatchKeyValue(entity, "upgradepack_explosive", "0");

		SpawnItemFinish(entity, _, _, vel);
		AddThingCount(name, FACTORYNAME_UPGRADE, 1);
	}
}

void InfectedFactoryCreate(char[] name, bool sim, bool skipCount = false)
{
	Log(sim, "Infected Factory Creating: %s", name);

	if (!sim)
	{
		// Check for any special commands
		if (StrEqual(name, "panic", false))
		{
			ClientCheatCommand(GetAnyClient(), "director_force_panic_event");

			if (!skipCount)
				AddThingCount(name, FACTORYNAME_INFECTED, 1);
		}
		else if (StrContains(name, "mob-", false) != -1)
		{
			char parts[2][10];
			if (ExplodeString(name, "-", parts, 2, 10) > 1)
			{
				SpawnHorde(parts[1]);
			}

			if (!skipCount)
				AddThingCount(name, FACTORYNAME_INFECTED, 1);
		}
		else if (StrEqual(name, "infected-team", false))
		{
			InfectedFactoryCreate("boomer auto", sim, true);
			InfectedFactoryCreate("hunter auto", sim, true);
			InfectedFactoryCreate("smoker auto", sim, true);
			InfectedFactoryCreate("spitter auto", sim, true);
			InfectedFactoryCreate("jockey auto", sim, true);
			InfectedFactoryCreate("charger auto", sim, true);

			if (!skipCount)
				AddThingCount(name, FACTORYNAME_INFECTED, 1);
		}
		else if (StrEqual(name, "boss-team", false))
		{
			InfectedFactoryCreate("tank auto", sim, true);
			InfectedFactoryCreate("witch auto", sim, true);

			if (!skipCount)
				AddThingCount(name, FACTORYNAME_INFECTED, 1);
		}
		else
		{
			if (!skipCount)
				AddThingCount(name, FACTORYNAME_INFECTED, 1);

			ReplaceString(name, 256, "_", " ");

			SpawnInfected(name);
		}
	}
}

void ExplodeFactoryCreate(char[] name, bool sim, float location[3])
{
	Log(sim, "Weapon Factory Creating: %s", name);

	if (!sim)
	{
		int entity = CreateEntityByName("physics_prop");
		location[2] += 20.0;

		if (StrEqual(name, "weapon_fireworkcrate", false))
		{
			SetEntityModel(entity, "models/props_junk/explosive_box001.mdl");
		}
		else if (StrEqual(name, "weapon_gascan", false)) {
			SetEntityModel(entity, "models/props_junk/gascan001a.mdl");
		}
		else if (StrEqual(name, "weapon_propanetank", false)) {
			SetEntityModel(entity, "models/props_junk/propanecanister001a.mdl");
			int tankRef = EntIndexToEntRef(entity);
			g_PropaneTanks.Push(tankRef);
			CleanupDeadTanks();
		}
		else if (StrEqual(name, "weapon_oxygentank", false)) {
			SetEntityModel(entity, "models/props_equipment/oxygentank01.mdl");
		}
		DispatchKeyValue(entity, "spawnflags", "1");
		DispatchSpawn(entity);
		// ActivateEntity(entity);
		TeleportEntity(entity, location, NULL_VECTOR, NULL_VECTOR);
		//PrintToChatAll("teleport entity:%s on:x:%.2f y:%.2f z:%.2f", name, location[0], location[1], location[2]);
		AddThingCount(name, FACTORYNAME_EXPLODE, 1);
	}
}

public Action CH_PassFilter(int ent1, int ent2, bool &result)
{
	//PrintToChatAll("CH_PassFilter ent1:%d ent2:%d result:%s", ent1, ent2, result ? "true" : "false");
	if ((IsPlayer(ent1) && IsPropaneTank(ent2)) || (IsPlayer(ent2) && IsPropaneTank(ent1)))
	{
		//PrintToChatAll("try change ptank");
		result = false;
		return Plugin_Changed;
	}
	return Plugin_Continue;
}

stock void CleanupDeadTanks()
{
	for (int i = g_PropaneTanks.Length - 1; i >= 0; i--)
	{
		int entRef = g_PropaneTanks.Get(i);
		if (EntRefToEntIndex(entRef) == INVALID_ENT_REFERENCE)
		{
			g_PropaneTanks.Erase(i);
		}
	}
}

stock bool IsPropaneTank(int entity)
{
	CleanupDeadTanks();

	int len = g_PropaneTanks.Length;
	for (int i = 0; i < len; i++)
	{
		int tankRef = g_PropaneTanks.Get(i);
		int tankEnt = EntRefToEntIndex(tankRef);
		if (tankEnt == entity)
		{
			return true;
		}
	}
	return false;
}

bool IsPlayer(int entity)
{
	return entity > 0 && entity <= MaxClients && IsClientInGame(entity) && (GetClientTeam(entity) == 2);
}

public bool TraceFilter_IgnoreSelf(int entity, int contentsMask, any data)
{
	return entity != data;
}