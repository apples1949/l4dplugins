void ClientCheatCommand(int client, const char[] command)
{
	int flags = GetCommandFlags(command);
	SetCommandFlags(command, flags & ~FCVAR_CHEAT);
	FakeClientCommand(client, command);
	SetCommandFlags(command, flags);
}

void SpawnInfected(const char[] name)
{
	Log(false, "zspawn %s", name);
	int flags = GetCommandFlags("z_spawn");
	SetCommandFlags("z_spawn", flags & ~FCVAR_CHEAT);
	FakeClientCommand(GetAnyClient(), "z_spawn %s", name);
	SetCommandFlags("z_spawn", flags);
}

void SpawnHorde(const char[] name)
{
	if (g_bSpawnUncommonSupported)
	{
		int flags = GetCommandFlags("sm_spawnuncommonhorde");
		SetCommandFlags("sm_spawnuncommonhorde", flags & ~ADMFLAG_CHEATS);
		FakeClientCommand(GetAnyClient(), "sm_spawnuncommonhorde %s", name);
		SetCommandFlags("sm_spawnuncommonhorde", flags);
	}
}

int SpawnItem(float location[3] = NULL_VECTOR, float angles[3] = NULL_VECTOR, float velocity[3] = NULL_VECTOR, const char[] name, const char[] model = MODEL_NONE, bool dontSpawn = false)
{
	int entity = CreateEntityByName(name);
	if (entity != -1)
	{
		if (StrEqual(model, MODEL_NONE) == false)
			SetEntityModel(entity, model);

		DispatchKeyValue(entity, "spawnflags", "1");

		if (!dontSpawn)
		{
			DispatchSpawn(entity);
			ActivateEntity(entity);
			TeleportEntity(entity, location, angles, velocity);
		}
	}
	return entity;
}

void SpawnItemFinish(int entity, float location[3] = NULL_VECTOR, float angles[3] = NULL_VECTOR, float velocity[3] = NULL_VECTOR)
{
	DispatchSpawn(entity);
	ActivateEntity(entity);
	// char weaponClass[64];
	// GetEdictClassname(entity, weaponClass, sizeof(weaponClass));
	// PrintToChatAll("teleport entity:%s on:x:%.2f y:%.2f z:%.2f", weaponClass, location[0], location[1], location[2]);	 //  halflife.inc
	TeleportEntity(entity, location, angles, velocity);
}

bool IsThingMaxReached(char[] name, char[] type)
{
	if (g_hMaxSpawns != null)
	{
		// Look up that thing and type. if 0 it was not found or set to 0 meaning don't max.
		int maxAmount = GetThingMax(name, type);

		// If -1, it's set to not allow.
		if (maxAmount == -1)
			return true;
		else if (maxAmount > 0)
		{
			// We have an amount, lets check for current
			return GetThingCount(name, type) >= maxAmount;
		}
	}

	return false;
}

int GetThingMax(char[] name, char[] type)
{
	if (g_hMaxSpawns != null)
	{
		char pathMax[256];
		Format(pathMax, sizeof(pathMax), "max_spawns.%s.%s", type, name);
		// Look up that thing and type. if 0 it was not found or set to 0 meaning don't max.
		return ConfigLookupInt(g_hConfig, pathMax);
	}
	return 0;
}

void AddThingCount(char[] name, char[] type, int countToAdd)
{
	if (g_hMaxSpawnsCounters != null)
	{
		Handle hThing;
		int	   thingCount = GetThingCount(name, type, hThing);

		if (hThing != null)
		{
			// Get the value, add one, return.
			ConfigSettingSetInt(hThing, thingCount + countToAdd);
		}
	}
}

int GetThingCount(char[] name, char[] type, Handle thing = null)
{
	if (g_hMaxSpawnsCounters != null)
	{
		// Find or create type
		Handle hType = ConfigSettingGetMember(g_hMaxSpawnsCounters, type);

		if (hType == null)
		{
			hType = ConfigSettingAdd(g_hMaxSpawnsCounters, type, ST_Group);

			if (hType == null)
			{
				Log(false, "Unable to create max_spawns_counters.%s", type);
				LogError("Unable to create max_spawns_counters.%s", type);
				thing = null;
				return 0;
			}
		}

		// Find or create thing
		thing = ConfigSettingGetMember(hType, name);

		if (thing == null)
		{
			thing = ConfigSettingAdd(hType, name, ST_Int);

			if (thing == null)
			{
				Log(false, "Unable to create max_spawns_counters.%s.%s", type, name);
				LogError("Unable to create max_spawns_counters.%s.%s", type, name);
				thing = null;
			}

			// Return here. We created it or didn't. Still return 0 and whatever the handle is.
			return 0;
		}

		// It exists already, so grab and return.
		return ConfigSettingGetInt(thing);
	}

	thing = null;
	return 0;
}

void Announce(char[] infectedText = NULL_STRING, char[] survivorText = NULL_STRING)
{
	if (g_iAnnounceMode != 0)
	{
		for (int i = 1; i <= MaxClients; i++)
		{
			if (IsClientInGame(i) && !IsFakeClient(i))
			{
				int team = GetClientTeam(i);

				if (!StrEqual(infectedText, NULL_STRING) && team == TEAM_INFECTED)
				{
					if (g_iAnnounceMode == 1)
					{
						PrintHintText(i, infectedText);
					}
					else if (g_iAnnounceMode == 2)
					{
						PrintToChat(i, infectedText);
					}
				}

				if (!StrEqual(survivorText, NULL_STRING) && team == TEAM_SURVIVOR)
				{
					if (g_iAnnounceMode == 1)
					{
						PrintHintText(i, survivorText);
					}
					else if (g_iAnnounceMode == 2)
					{
						PrintToChat(i, survivorText);
					}
				}
			}
		}
	}
}

///////////////////
// Helpers
///////////////////
int GetAnyClient()
{
	for (int i = 1; i <= MaxClients; i++)
	{
		if (IsClientInGame(i))
		{
			return i;
		}
	}
	return 0;
}

void Log(bool sim, const char[] format, any...)
{
	char newString[256];
	VFormat(newString, sizeof(newString), format, 3);

	if (sim)
	{
		PrintToChatAll(newString);
		PrintToServer(newString);
	}
	else if (g_bWriteLog)
	{
		LogMessage(newString);
		PrintToServer(newString);
	}
}

int ConfigSettingGetMemberInt(Handle setting, char[] name)
{
	Handle hMember = ConfigSettingGetMember(setting, name);
	if (hMember != null)
		return ConfigSettingGetInt(hMember);
	else
		return -1;
}

stock int StrToLower(const char[] str, char[] buffer, int bufsize)
{
	int n = 0, x = 0;
	while (str[n] != '\0' && x < (bufsize - 1))
	{							// Make sure we are inside bounds
		int Char = str[n++];	// Caching

		if (IsCharUpper(Char))
		{								 // Am I big ?
			Char = CharToLower(Char);	 // Big becomes low
		}

		buffer[x++] = Char;	   // Write into our new string
	}

	buffer[x++] = '\0';	   // Finalize with the end ( = always 0 for strings)

	return x;	 // return number of bytes written for later proove
}

///////////////////
// Factories
///////////////////
void ItemFactoryCreate(char[] itemName, bool sim, float location[3])
{
	Log(sim, "Item Factory Creating: %s", itemName);

	if (!sim)
	{
		// Mod location so it spawns around mid level of model.
		location[2] += 10.0;

		// Create random velocity
		float vel[3];
		vel[0] = GetRandomFloat(-80.0, 80.0);
		vel[1] = GetRandomFloat(-80.0, 80.0);
		vel[2] = GetRandomFloat(40.0, 80.0);

		SpawnItem(location, _, vel, itemName);
		// PrintToChatAll("Create entity:%s location: x:%.2f y:%.2f z:%.2f", itemName, location[0], location[1], location[2]);	//  halflife.inc
		AddThingCount(itemName, FACTORYNAME_ITEM, 1);
	}
}

void WeaponFactoryCreate(char[] name, bool sim, float location[3])
{
	Log(sim, "Weapon Factory Creating: %s", name);

	if (!sim)
	{
		int entity = SpawnItem(_, _, _, "weapon_spawn", _, true);

		// Mod location so it spawns around mid level of model.
		location[2] += 10.0;

		// Create random velocity
		float vel[3];
		vel[0] = GetRandomFloat(-80.0, 80.0);
		vel[1] = GetRandomFloat(-80.0, 80.0);
		vel[2] = GetRandomFloat(40.0, 80.0);
		// PrintToChatAll("set entity %s origin kv to x:%.2f y:%.2f z:%.2f", name, location[0], location[1], location[2]);  //  halflife.inc
		DispatchKeyValueVector(entity, "origin", location);
		DispatchKeyValue(entity, "weapon_selection", name);
		// PrintToChatAll("set weaopn_spawn to name(%s) %s ", name, DispatchKeyValue(entity, "weapon_selection", name) ? "ture" : "false");
		DispatchKeyValue(entity, "spawnflags", "1");
		DispatchKeyValue(entity, "solid", "6");
		DispatchKeyValue(entity, "count", "1");
		DispatchKeyValue(entity, "body", "0");
		DispatchKeyValue(entity, "spawn_without_director", "1");

		SpawnItemFinish(entity, _, _, vel);
		AddThingCount(name, FACTORYNAME_WEAPON, 1);
	}
}

void MeleeFactoryCreate(char[] name, bool sim, float location[3])
{
	Log(sim, "Melee Factory Creating: %s", name);

	if (!sim)
	{
		int entity = SpawnItem(_, _, _, "weapon_melee_spawn", _, true);

		// Mod location so it spawns around mid level of model.
